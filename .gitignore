# Local secrets — never commit real env files, only .env.example
.env
.env.local
deployments/helm/flight-tracker/values-local.yaml
# values-demo.yaml is intentionally committed (not ignored) — this is a
# throwaway demo bot, not a product, so the real Telegram token/DB
# passwords inside it are committed on purpose so anyone can clone and
# `./deploy-demo.sh` without extra setup. Rotate the token via @BotFather
# if this ever needs to stop being public.

# Build artifacts
bin/
*.exe
*.test

# Local dev script output (see services/*/scripts/)
logs/
*.log
deployments/helm/flight-tracker/charts/*/charts/
deployments/helm/flight-tracker/charts/*.tgz
deployments/helm/flight-tracker/charts/*/Chart.lock
deployments/helm/flight-tracker/Chart.lock

# Go
go.work.sum

# CKAD labs: scripts/solve.sh writes YAML manifests here at run time —
# scratch output, not lab source (the same content is embedded in
# scripts/solve.sh itself).
ckad-labs/**/manifests/
