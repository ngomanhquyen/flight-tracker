# Local development only. In deployed environments these are set via
# Kubernetes ConfigMap/Secret env vars (see deployments/helm/flight-tracker/charts/bot-service),
# never via this file.

BOT_ENVIRONMENT=local
BOT_HTTP_PORT=8080
BOT_HTTP_SHUTDOWN_TIMEOUT=15s

BOT_TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token
BOT_TELEGRAM_WEBHOOK_SECRET=change-me-webhook-header-secret
BOT_TELEGRAM_WEBHOOK_PATH_SECRET=change-me-webhook-path-secret
BOT_TELEGRAM_REQUEST_TIMEOUT=10s

BOT_CLIENTS_FLIGHT_SERVICE_URL=http://localhost:8081
BOT_CLIENTS_SUBSCRIPTION_SERVICE_URL=http://localhost:8082
BOT_CLIENTS_TIMEOUT=5s
