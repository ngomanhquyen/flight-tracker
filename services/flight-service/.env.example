# Local development only. In deployed environments these are set via
# Kubernetes ConfigMap/Secret env vars (see deployments/helm/flight-tracker/charts/flight-service),
# never via this file.

FLIGHT_ENVIRONMENT=local
FLIGHT_HTTP_PORT=8081
FLIGHT_HTTP_SHUTDOWN_TIMEOUT=15s

FLIGHT_DB_HOST=localhost
FLIGHT_DB_PORT=5432
FLIGHT_DB_USER=postgres
FLIGHT_DB_PASSWORD=postgres
FLIGHT_DB_NAME=flight_tracker
FLIGHT_DB_SSLMODE=disable

FLIGHT_REDIS_ADDR=localhost:6379
FLIGHT_REDIS_PASSWORD=
FLIGHT_REDIS_DB=0

FLIGHT_CACHE_TTL=60s
FLIGHT_SEARCH_MAX_ROUTE_RESULTS=50
