# Local development only. In deployed environments these are set via
# Kubernetes ConfigMap/Secret env vars (see deployments/helm/flight-tracker/charts/sync-service),
# never via this file.

SYNC_ENVIRONMENT=local
SYNC_HTTP_PORT=8090
SYNC_HTTP_SHUTDOWN_TIMEOUT=15s

SYNC_DB_HOST=localhost
SYNC_DB_PORT=5432
SYNC_DB_USER=postgres
SYNC_DB_PASSWORD=postgres
SYNC_DB_NAME=flight_tracker
SYNC_DB_SSLMODE=disable

SYNC_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
SYNC_RABBITMQ_EXCHANGE=flight.events

SYNC_CLIENTS_FLIGHT_SERVICE_URL=http://localhost:8081
SYNC_CLIENTS_TIMEOUT=5s

# "fake" is the only provider implemented today (internal/repository/fake_provider.go).
SYNC_PROVIDER_NAME=fake
# RFC3339 timestamp; pins the fake provider's "now" to exercise a specific
# status transition on demand instead of waiting on the wall clock.
# Leave empty for normal (real wall-clock) behavior.
SYNC_PROVIDER_FAKE_NOW_OVERRIDE=
